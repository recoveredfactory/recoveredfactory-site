{
  "name": "recoveredfactory-ghost",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "dev:sst": "sst dev",
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && pnpm -r build",
    "build:web": "pnpm -C apps/web build",
    "lint": "pnpm -C apps/web lint",
    "format": "pnpm -C apps/web format",
    "deploy": "sst deploy"
  },
  "devDependencies": {
    "sst": "^3.0.0",
    "@inlang/paraglide-js": "^2.8.0"
  }
}
